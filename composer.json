{
    "name": "fr3on/laravel-forecast",
    "description": "Preview pending migration impact — row counts, lock estimates, and risk ratings — before you run migrate.",
    "type": "library",
    "keywords": ["laravel", "migrations", "database", "schema", "artisan"],
    "homepage": "https://github.com/fr3on/laravel-forecast",
    "license": "MIT",
    "authors": [
        {
            "name": "Ahmed Mardi",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelForecast\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelForecast\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelForecast\\ForecastServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
